# ============================================================
# Frontend Environment Variables — odooHQ26
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Vite exposes only variables prefixed with VITE_ to the browser.
# Never put secrets (JWT keys, DB passwords) here.
# ============================================================

# ------------------------------------------------------------
# Backend API
# Base URL of the running backend server (no trailing slash).
# Default: http://localhost:4000/api/v1  (matches backend PORT=4000)
# ------------------------------------------------------------
VITE_API_BASE_URL=http://localhost:4000/api/v1

# ------------------------------------------------------------
# App metadata (optional — used in <title> / meta tags)
# ------------------------------------------------------------
VITE_APP_NAME=TransitOps
VITE_APP_VERSION=1.0.0

# ------------------------------------------------------------
# Feature flags (set to "true" / "false")
# VITE_USE_MOCK_DATA=true  → app uses hardcoded mock data (no backend needed)
# VITE_USE_MOCK_DATA=false → app hits the real backend API
# ------------------------------------------------------------
VITE_USE_MOCK_DATA=true